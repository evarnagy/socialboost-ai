rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Default deny for any collection/path not explicitly allowed below.
    match /{document=**} {
      allow read, write: if false;
    }

    // All user data is stored under users/{uid}/...
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Business profile document: users/{uid}/profile/main
      match /profile/{profileId} {
        allow read, write: if isOwner(userId);
      }

      // Saved favorites: users/{uid}/favorites/{favoriteId}
      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId);
      }

      // Generated content cache: users/{uid}/generated/{docId}
      match /generated/{docId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
